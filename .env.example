# =============================================================================
# WheelShift Pro — Environment Variables Example
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_URL=jdbc:mysql://localhost:3307/wheelshift_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# MySQL root password (used by the mysql Docker container)
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=wheelshift_db
MYSQL_USER=your_db_username
MYSQL_PASSWORD=your_db_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Apache Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# JWT
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_cryptographically_secure_random_hex_string_min_256_bits
JWT_EXPIRATION_MS=86400000

# -----------------------------------------------------------------------------
# AI Service
# -----------------------------------------------------------------------------
AI_SERVICE_BASE_URL=http://localhost:8000
# Must match the API_KEY configured in the WheelShift AI service .env
AI_SERVICE_API_KEY=replace_with_ai_service_api_key
AI_SERVICE_ENABLED=true

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
FILE_STORAGE_BASE_PATH=uploads
FILE_STORAGE_TYPE=local

# AWS S3 (only required when FILE_STORAGE_TYPE=s3 or hybrid)
# AWS_ACCESS_KEY=your_aws_access_key
# AWS_SECRET_KEY=your_aws_secret_key
# S3_BUCKET_NAME=your_s3_bucket_name
# S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Spring / Server
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
